{
    "websocket_message_types": {
        "unspecified": "0x0001",

        "authRequest": "0x0101",
        "authSuccess": "0x0102",
        "authRegister": "0x0103",
        "authUnauthorized": "0x0104",
        "authInvalid": "0x0105",
        "authForbidden": "0x0106",

        "requestUsers": "0x0201",

        "userActivityPause": "0x0301",
        "userActivityResume": "0x0302"
    },
    "modules": {
        "Logger": {
            "isEnabled": true,
            "dependencies": [],
            "subPath": "/",
            "doKeepInstanceAsModule": true,
            "config": {
                "doWrapWithLogger": false,
                "doAnnounceWrapping": true,
                "doAnnounceCalling": true,
                "doAddTimestamp": true
            }
        },
        "Toolbox": {
            "isEnabled": true,
            "dependencies": [],
            "subPath": "/",
            "doKeepInstanceAsModule": true,
            "config": {
                "doWrapWithLogger": true
            }
        },
        "SocketClient": {
            "isEnabled": true,
            "dependencies": [],
            "subPath": "/ws/",
            "doKeepInstanceAsModule": false,
            "config": {
                "doWrapWithLogger": true,
                "doAllowMultipleConnections": true
            }
        },
        "SocketClientTable": {
            "isEnabled": true,
            "dependencies": ["SocketClient"],
            "subPath": "/ws/",
            "doKeepInstanceAsModule": true,
            "config": {
                "doWrapWithLogger": true
            }
        },
        "SocketMessage": {
            "isEnabled": true,
            "dependencies": [],
            "subPath": "/ws/",
            "doKeepInstanceAsModule": false,
            "config": {
                "doWrapWithLogger": true,
                "doParseUnknownAsUnspecified": false
            }
        },
        "SocketConnection": {
            "isEnabled": true,
            "dependencies": ["SocketMessage", "SocketClientTable"],
            "subPath": "/ws/",
            "doKeepInstanceAsModule": false,
            "config": {
                "doWrapWithLogger": true,
                "doLogOutcomingMessages": true,
                "doLogIncomingMessages": true
            }
        },
        "SocketServer": {
            "isEnabled": true,
            "dependencies": ["Logger", "SocketConnection", "Toolbox"],
            "doKeepInstanceAsModule": true,
            "subPath": "/ws/",
            "config": {
                "doWrapWithLogger": true,
                "port": "8082",
                "heartbeat": "2"
            }
        }
    }
}