{
    "websocket": {
        "port": "8082",
        "heartbeat": "30",
        "clients": {
            "doAllowMultipleConnections": true
        },
        "message_types": {
            "AUTH_REQUEST": "0x0101",
            "AUTH_SUCCESS": "0x0102",
            "REQUEST_USERS": "0x0201",
            "USER_ACTIVITY_PAUSE": "0x0301",
            "USER_ACTIVITY_RESUME": "0x0302"
        }
    },
    "modules": {
        "Toolbox": {
            "isEnabled": true,
            "dependencies": [],
            "doWrapWithLogger": true,
            "subPath": "/"
        },
        "SocketClient": {
            "isEnabled": false,
            "dependencies": [],
            "doWrapWithLogger": true,
            "subPath": "/ws/"
        },
        "SocketClientTable": {
            "isEnabled": false,
            "dependencies": [],
            "doWrapWithLogger": true,
            "subPath": "/ws/"
        },
        "SocketServer": {
            "isEnabled": true,
            "dependencies": ["Toolbox"],
            "doWrapWithLogger": true,
            "subPath": "/ws/"
        },
        "Logger": {
            "isEnabled": false,
            "dependencies": [],
            "doWrapWithLogger": false,
            "subPath": "/"
        }
    }
}